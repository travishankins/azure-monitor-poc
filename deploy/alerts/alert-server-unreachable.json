{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Contoso PoC — Alert: Server Unreachable. Fires when an AMA heartbeat is missing for more than 5 minutes."
  },
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Log Analytics workspace."
      }
    },
    "workspaceResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Resource group containing the Log Analytics workspace."
      }
    },
    "actionGroupName": {
      "type": "string",
      "defaultValue": "ag-contoso-poc",
      "metadata": {
        "description": "Name of the Action Group to trigger."
      }
    },
    "heartbeatThresholdMinutes": {
      "type": "int",
      "defaultValue": 5,
      "metadata": {
        "description": "Minutes without a heartbeat before alerting."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "variables": {
    "alertName": "alert-contoso-server-unreachable",
    "workspaceResourceId": "[resourceId(parameters('workspaceResourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]",
    "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', parameters('actionGroupName'))]",
    "query": "[concat('Heartbeat\n| summarize LastHeartbeat = max(TimeGenerated) by Computer, ResourceId\n| where LastHeartbeat < ago(', parameters('heartbeatThresholdMinutes'), 'm)\n| project Computer, LastHeartbeat, MinutesSinceHeartbeat = datetime_diff(\"minute\", now(), LastHeartbeat), ResourceId')]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[variables('alertName')]",
      "location": "[parameters('location')]",
      "tags": {
        "project": "contoso-monitor-poc",
        "scope": "availability",
        "scomEquivalent": "Heartbeat Monitor",
        "severity": "critical",
        "createdBy": "arm-template"
      },
      "properties": {
        "displayName": "Contoso PoC — Server Unreachable (No Heartbeat)",
        "description": "[concat('Fires when a monitored server has not sent a heartbeat for more than ', parameters('heartbeatThresholdMinutes'), ' minutes. SCOM equivalent: Agent Heartbeat / Health Service Heartbeat Failure.')]",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT10M",
        "scopes": ["[variables('workspaceResourceId')]"],
        "criteria": {
          "allOf": [
            {
              "query": "[variables('query')]",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                {
                  "name": "Computer",
                  "operator": "Include",
                  "values": ["*"]
                }
              ],
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "autoMitigate": true,
        "actions": {
          "actionGroups": ["[variables('actionGroupId')]"]
        }
      }
    }
  ],
  "outputs": {
    "alertRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/scheduledQueryRules', variables('alertName'))]"
    }
  }
}
