{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Contoso PoC — Alert: Low Memory. Creates warning (<1GB available) and critical (<500MB available) alert rules."
  },
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Log Analytics workspace."
      }
    },
    "workspaceResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Resource group containing the Log Analytics workspace."
      }
    },
    "actionGroupName": {
      "type": "string",
      "defaultValue": "ag-contoso-poc"
    },
    "memoryWarningThresholdMB": {
      "type": "int",
      "defaultValue": 1024,
      "metadata": {
        "description": "Available memory (MB) below which a warning is raised."
      }
    },
    "memoryCriticalThresholdMB": {
      "type": "int",
      "defaultValue": 500,
      "metadata": {
        "description": "Available memory (MB) below which a critical alert is raised."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "variables": {
    "workspaceResourceId": "[resourceId(parameters('workspaceResourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]",
    "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', parameters('actionGroupName'))]",
    "warningQuery": "[concat('Perf\n| where ObjectName == \"Memory\" and CounterName == \"Available MBytes\"\n| summarize AvgAvailMB = avg(CounterValue) by Computer, bin(TimeGenerated, 5m)\n| where AvgAvailMB < ', parameters('memoryWarningThresholdMB'), '\n| project Computer, AvgAvailMB, TimeGenerated')]",
    "criticalQuery": "[concat('Perf\n| where ObjectName == \"Memory\" and CounterName == \"Available MBytes\"\n| summarize AvgAvailMB = avg(CounterValue) by Computer, bin(TimeGenerated, 5m)\n| where AvgAvailMB < ', parameters('memoryCriticalThresholdMB'), '\n| project Computer, AvgAvailMB, TimeGenerated')]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "alert-contoso-memory-warning",
      "location": "[parameters('location')]",
      "tags": {
        "project": "contoso-monitor-poc",
        "scope": "performance",
        "scomEquivalent": "Memory\\Available MBytes",
        "severity": "warning",
        "createdBy": "arm-template"
      },
      "properties": {
        "displayName": "[concat('Contoso PoC — Low Memory Warning (<', parameters('memoryWarningThresholdMB'), ' MB)')]",
        "description": "[concat('Fires when average available memory drops below ', parameters('memoryWarningThresholdMB'), ' MB. SCOM equivalent: Windows Server Operating System / Available Megabytes of Memory threshold.')]",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT10M",
        "scopes": ["[variables('workspaceResourceId')]"],
        "criteria": {
          "allOf": [
            {
              "query": "[variables('warningQuery')]",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                {
                  "name": "Computer",
                  "operator": "Include",
                  "values": ["*"]
                }
              ],
              "failingPeriods": {
                "numberOfEvaluationPeriods": 2,
                "minFailingPeriodsToAlert": 2
              }
            }
          ]
        },
        "autoMitigate": true,
        "actions": {
          "actionGroups": ["[variables('actionGroupId')]"]
        }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "alert-contoso-memory-critical",
      "location": "[parameters('location')]",
      "tags": {
        "project": "contoso-monitor-poc",
        "scope": "performance",
        "scomEquivalent": "Memory\\Available MBytes",
        "severity": "critical",
        "createdBy": "arm-template"
      },
      "properties": {
        "displayName": "[concat('Contoso PoC — Low Memory Critical (<', parameters('memoryCriticalThresholdMB'), ' MB)')]",
        "description": "[concat('Fires when average available memory drops below ', parameters('memoryCriticalThresholdMB'), ' MB. SCOM equivalent: Windows Server Operating System / Available Megabytes of Memory critical threshold.')]",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT5M",
        "scopes": ["[variables('workspaceResourceId')]"],
        "criteria": {
          "allOf": [
            {
              "query": "[variables('criticalQuery')]",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                {
                  "name": "Computer",
                  "operator": "Include",
                  "values": ["*"]
                }
              ],
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "autoMitigate": true,
        "actions": {
          "actionGroups": ["[variables('actionGroupId')]"]
        }
      }
    }
  ],
  "outputs": {
    "warningAlertId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/scheduledQueryRules', 'alert-contoso-memory-warning')]"
    },
    "criticalAlertId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/scheduledQueryRules', 'alert-contoso-memory-critical')]"
    }
  }
}
