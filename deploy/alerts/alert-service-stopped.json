{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Contoso PoC — Alert: Critical Windows Service Stopped. Detects when DHCP, SCCM Executive, DNS, W32Time, NTDS, or other critical services stop."
  },
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Log Analytics workspace."
      }
    },
    "workspaceResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Resource group containing the Log Analytics workspace."
      }
    },
    "actionGroupName": {
      "type": "string",
      "defaultValue": "ag-contoso-poc"
    },
    "criticalServices": {
      "type": "array",
      "defaultValue": [
        "DHCP Server",
        "CcmExec",
        "SMS_EXECUTIVE",
        "W32Time",
        "DNS",
        "NTDS"
      ],
      "metadata": {
        "description": "List of critical Windows service names to monitor."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "variables": {
    "alertName": "alert-contoso-service-stopped",
    "workspaceResourceId": "[resourceId(parameters('workspaceResourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]",
    "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', parameters('actionGroupName'))]",
    "serviceList": "[replace(replace(string(parameters('criticalServices')), '[', ''), ']', '')]",
    "query": "[concat('Event\n| where EventLog == \"System\" and Source == \"Service Control Manager\" and EventID == 7036\n| parse EventData with * ''<Data Name=\"param1\">'' ServiceName ''</Data><Data Name=\"param2\">'' ServiceState ''</Data>'' *\n| where ServiceState has \"stopped\"\n| where ServiceName in~ (', variables('serviceList'), ')\n| project TimeGenerated, Computer, ServiceName, ServiceState, EventData')]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[variables('alertName')]",
      "location": "[parameters('location')]",
      "tags": {
        "project": "contoso-monitor-poc",
        "scope": "services",
        "scomEquivalent": "Windows Service Monitor",
        "severity": "critical",
        "createdBy": "arm-template"
      },
      "properties": {
        "displayName": "Contoso PoC — Critical Windows Service Stopped",
        "description": "Fires when a critical Windows service (DHCP, SCCM, DNS, W32Time, NTDS, etc.) enters a stopped state. SCOM equivalent: Windows Service management pack monitors.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT5M",
        "scopes": ["[variables('workspaceResourceId')]"],
        "criteria": {
          "allOf": [
            {
              "query": "[variables('query')]",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                {
                  "name": "Computer",
                  "operator": "Include",
                  "values": ["*"]
                }
              ],
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "autoMitigate": true,
        "actions": {
          "actionGroups": ["[variables('actionGroupId')]"]
        }
      }
    }
  ],
  "outputs": {
    "alertRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/scheduledQueryRules', variables('alertName'))]"
    }
  }
}
