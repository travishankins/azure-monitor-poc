{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Contoso PoC — Alert: High CPU Usage. Creates both a warning (85%) and critical (95%) alert rule."
  },
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Log Analytics workspace."
      }
    },
    "workspaceResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Resource group containing the Log Analytics workspace."
      }
    },
    "actionGroupName": {
      "type": "string",
      "defaultValue": "ag-contoso-poc"
    },
    "cpuWarningThreshold": {
      "type": "int",
      "defaultValue": 85,
      "metadata": {
        "description": "CPU % threshold for warning alert."
      }
    },
    "cpuCriticalThreshold": {
      "type": "int",
      "defaultValue": 95,
      "metadata": {
        "description": "CPU % threshold for critical alert."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "variables": {
    "workspaceResourceId": "[resourceId(parameters('workspaceResourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]",
    "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', parameters('actionGroupName'))]",
    "warningQuery": "[concat('Perf\n| where ObjectName == \"Processor\" and CounterName == \"% Processor Time\" and InstanceName == \"_Total\"\n| summarize AvgCPU = avg(CounterValue) by Computer, bin(TimeGenerated, 5m)\n| where AvgCPU > ', parameters('cpuWarningThreshold'), '\n| project Computer, AvgCPU, TimeGenerated')]",
    "criticalQuery": "[concat('Perf\n| where ObjectName == \"Processor\" and CounterName == \"% Processor Time\" and InstanceName == \"_Total\"\n| summarize AvgCPU = avg(CounterValue) by Computer, bin(TimeGenerated, 5m)\n| where AvgCPU > ', parameters('cpuCriticalThreshold'), '\n| project Computer, AvgCPU, TimeGenerated')]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "alert-contoso-cpu-warning",
      "location": "[parameters('location')]",
      "tags": {
        "project": "contoso-monitor-poc",
        "scope": "performance",
        "scomEquivalent": "Processor\\% Processor Time",
        "severity": "warning",
        "createdBy": "arm-template"
      },
      "properties": {
        "displayName": "[concat('Contoso PoC — CPU Usage Warning (>', parameters('cpuWarningThreshold'), '%)')]",
        "description": "[concat('Fires when average CPU on a server exceeds ', parameters('cpuWarningThreshold'), '% over a 10-minute window. SCOM equivalent: Windows Server Operating System / Processor % Processor Time warning threshold.')]",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT10M",
        "scopes": ["[variables('workspaceResourceId')]"],
        "criteria": {
          "allOf": [
            {
              "query": "[variables('warningQuery')]",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                {
                  "name": "Computer",
                  "operator": "Include",
                  "values": ["*"]
                }
              ],
              "failingPeriods": {
                "numberOfEvaluationPeriods": 2,
                "minFailingPeriodsToAlert": 2
              }
            }
          ]
        },
        "autoMitigate": true,
        "actions": {
          "actionGroups": ["[variables('actionGroupId')]"]
        }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "alert-contoso-cpu-critical",
      "location": "[parameters('location')]",
      "tags": {
        "project": "contoso-monitor-poc",
        "scope": "performance",
        "scomEquivalent": "Processor\\% Processor Time",
        "severity": "critical",
        "createdBy": "arm-template"
      },
      "properties": {
        "displayName": "[concat('Contoso PoC — CPU Usage Critical (>', parameters('cpuCriticalThreshold'), '%)')]",
        "description": "[concat('Fires when average CPU on a server exceeds ', parameters('cpuCriticalThreshold'), '% over a 5-minute window. SCOM equivalent: Windows Server Operating System / Processor % Processor Time critical threshold.')]",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT5M",
        "scopes": ["[variables('workspaceResourceId')]"],
        "criteria": {
          "allOf": [
            {
              "query": "[variables('criticalQuery')]",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                {
                  "name": "Computer",
                  "operator": "Include",
                  "values": ["*"]
                }
              ],
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "autoMitigate": true,
        "actions": {
          "actionGroups": ["[variables('actionGroupId')]"]
        }
      }
    }
  ],
  "outputs": {
    "warningAlertId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/scheduledQueryRules', 'alert-contoso-cpu-warning')]"
    },
    "criticalAlertId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/scheduledQueryRules', 'alert-contoso-cpu-critical')]"
    }
  }
}
